<div class="tab-pane" id="{{ repo_tab.id }}">
  <div class="metric-grid">
    <div class="metric-card">
      <div class="metric-label">Repository</div>
      <div class="metric-value">{{ repo_tab.name }}</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Scope</div>
      <div class="metric-value">Repository tab</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Filters</div>
      <div class="metric-value">Language / Author</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Rendering</div>
      <div class="metric-value">On first open</div>
    </div>
  </div>
  <div class="row row-cols-1 row-cols-lg-2 g-3 mb-3">
    <div class="col">
      <div class="card table-panel">
        <div class="card-header">Languages (Top 10)</div>
        <div class="card-body">
          <div id="repo-{{ repo_tab.id }}-language-table" class="report-table" data-report-table="true">
            <div class="report-placeholder">Open this tab to render.</div>
          </div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card table-panel">
        <div class="card-header">Authors (Top 10)</div>
        <div class="card-body">
          <div id="repo-{{ repo_tab.id }}-author-table" class="report-table" data-report-table="true">
            <div class="report-placeholder">Open this tab to render.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="row row-cols-1 row-cols-lg-2 g-3 mb-3">
    <div class="col">
      <div class="card tag-card" data-filter-tab="{{ repo_tab.id }}" data-filter-group="language">
        <div class="card-header">
          <span>Language Tags</span>
          <span class="tag-count" data-tag-count>0 tags</span>
          <div class="card-actions">
            <button class="btn btn-sm btn-ghost-secondary" type="button" data-tag-clear>Clear filters</button>
          </div>
        </div>
        <div class="card-body">
          <input class="form-control form-control-sm mb-2" type="text" placeholder="Search..." data-tag-search>
          <div class="tag-list" data-tag-list></div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card tag-card" data-filter-tab="{{ repo_tab.id }}" data-filter-group="author">
        <div class="card-header">
          <span>Author Tags</span>
          <span class="tag-count" data-tag-count>0 tags</span>
          <div class="card-actions">
            <button class="btn btn-sm btn-ghost-secondary" type="button" data-tag-clear>Clear filters</button>
          </div>
        </div>
        <div class="card-body">
          <input class="form-control form-control-sm mb-2" type="text" placeholder="Search..." data-tag-search>
          <div class="tag-list" data-tag-list></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-12">
      <div class="card chart-panel">
        <div class="card-header">Language Trend</div>
        <div class="card-body">
          <div id="repo-{{ repo_tab.id }}-language-chart" data-report-chart="true"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-12">
      <div class="card chart-panel">
        <div class="card-header">Author Trend</div>
        <div class="card-body">
          <div id="repo-{{ repo_tab.id }}-author-chart" data-report-chart="true"></div>
        </div>
      </div>
    </div>
  </div>
</div>
