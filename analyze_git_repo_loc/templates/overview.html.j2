<div class="tab-pane active" id="overview">
  <div class="row mb-3">
    <div class="col-12">
      <div class="card">
        <div class="card-header">Run Overview</div>
        <div class="card-body">
          <ul class="meta-list">
            {% for item in overview.meta_items %}
            <li>{{ item.label }}: {{ item.value }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
  <div class="row row-cols-1 row-cols-lg-2 g-3 mb-3">
    <div class="col">
      <div class="card">
        <div class="card-header">Repositories (Top 10)</div>
        <div class="card-body">
          <div id="overview-repo-table"></div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card tag-card" data-filter-tab="overview" data-filter-group="repository">
        <div class="card-header">
          Repository Tags
          <div class="card-actions">
            <button class="btn btn-sm btn-ghost-secondary" type="button" data-tag-clear>Clear filters</button>
          </div>
        </div>
        <div class="card-body">
          <input class="form-control form-control-sm mb-2" type="text" placeholder="Search..." data-tag-search>
          <div class="tag-list" data-tag-list></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row row-cols-1 row-cols-lg-2 g-3 mb-3">
    <div class="col">
      <div class="card">
        <div class="card-header">Languages (Top 10)</div>
        <div class="card-body">
          <div id="overview-language-table"></div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card">
        <div class="card-header">Authors (Top 10)</div>
        <div class="card-body">
          <div id="overview-author-table"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row row-cols-1 row-cols-lg-2 g-3 mb-3">
    <div class="col">
      <div class="card tag-card" data-filter-tab="overview" data-filter-group="language">
        <div class="card-header">
          Language Tags
          <div class="card-actions">
            <button class="btn btn-sm btn-ghost-secondary" type="button" data-tag-clear>Clear filters</button>
          </div>
        </div>
        <div class="card-body">
          <input class="form-control form-control-sm mb-2" type="text" placeholder="Search..." data-tag-search>
          <div class="tag-list" data-tag-list></div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="card tag-card" data-filter-tab="overview" data-filter-group="author">
        <div class="card-header">
          Author Tags
          <div class="card-actions">
            <button class="btn btn-sm btn-ghost-secondary" type="button" data-tag-clear>Clear filters</button>
          </div>
        </div>
        <div class="card-body">
          <input class="form-control form-control-sm mb-2" type="text" placeholder="Search..." data-tag-search>
          <div class="tag-list" data-tag-list></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row mb-3">
    <div class="col-12">
      <div class="card">
        <div class="card-header">Repository Trend</div>
        <div class="card-body">
          <div id="overview-repo-trend-chart"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">Author Contribution</div>
        <div class="card-body">
          <div id="overview-author-contrib-chart"></div>
        </div>
      </div>
    </div>
  </div>
</div>
